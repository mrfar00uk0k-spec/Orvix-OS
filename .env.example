# ============================================================
# Orvix OS — Environment Variables
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية أول ما توصل لكل مرحلة
# cp .env.example .env
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Database — PostgreSQL + Prisma (Phase 2) ---
DATABASE_URL=
DIRECT_URL=

# --- Auth — Clerk (Phase 3) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=

# --- Storage — Supabase Storage (Phase 6) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=knowledge-base

# --- Vector database — Qdrant (Phase 6) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Redis / Queue — BullMQ (Phase 5) ---
REDIS_URL=

# --- AI providers (Phase 7) ---
GEMINI_API_KEY=
GROK_API_KEY=
AI_ENCRYPTION_SECRET=

# --- Channels — WhatsApp / Facebook / Instagram (Phase 8) ---
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
FACEBOOK_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=

# --- Payments — Paymob, EGP (Phase 9) ---
PAYMOB_API_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# --- Email — Resend (Phase 5) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Security / misc (Phase 5, 8) ---
ENCRYPTION_SECRET=
CRON_SECRET=
