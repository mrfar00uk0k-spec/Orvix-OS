// ============================================================
// SmartDesk AI — Prisma Schema
// PostgreSQL stores relational data + metadata only.
// Vector embeddings live in Qdrant — see Embedding model below,
// which stores a pointer (qdrantPointId), never the vector itself.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------
// Enums
// ------------------------------------------------------------

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  EXPIRED
  CANCELLED
}

/// Reserves identifiers for providers not yet implemented (OpenAI, Claude,
/// DeepSeek) so the Provider Router can support them later without a schema
/// change — only Gemini and Grok have a real AIProvider implementation today.
enum AiProviderName {
  GEMINI
  GROK
  OPENAI
  CLAUDE
  DEEPSEEK
}

enum AiPersonality {
  PROFESSIONAL
  FRIENDLY
  LUXURY
  MEDICAL
  SALES
  SUPPORT
  MINIMAL
}

enum AiLanguageMode {
  AR
  EN
  AUTO
}

enum ReplyLength {
  SHORT
  DETAILED
}

enum KnowledgeBaseStatus {
  EMPTY
  PROCESSING
  READY
  FAILED
}

/// MANUAL covers the rich-text "Manual Text" tab — it flows through the same
/// KnowledgeFile → KnowledgeChunk → Embedding pipeline as uploaded files so
/// retrieval doesn't need a second code path. Version history for manual
/// entries is added in Phase 6 alongside the rest of the Knowledge Base UI.
enum KnowledgeFileType {
  PDF
  TXT
  MANUAL
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ChannelType {
  WHATSAPP
  FACEBOOK
  INSTAGRAM
}

enum ChannelConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  TOKEN_EXPIRED
}

enum ConversationStatus {
  ACTIVE
  RESOLVED
  PENDING_INFO
}

/// Only CUSTOMER and AI — the product has no human agents or handoff.
enum MessageSender {
  CUSTOMER
  AI
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum NotificationType {
  NEW_UPLOAD
  KNOWLEDGE_READY
  CHANNEL_CONNECTED
  SUBSCRIPTION_EXPIRING
  AI_ERROR
  PAYMENT_SUCCESS
  PAYMENT_FAILED
}

enum WebhookProvider {
  WHATSAPP
  FACEBOOK
  INSTAGRAM
  PAYMOB
  CLERK
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

enum QueueStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}

enum QueueStep {
  EXTRACT
  CLEAN
  CHUNK
  EMBED
  STORE
}

enum EmailType {
  WELCOME
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  KNOWLEDGE_PROCESSING_FINISHED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  VISA
  MASTERCARD
  MEEZA
  VODAFONE_CASH
  ORANGE_CASH
  ETISALAT_CASH
}

enum SystemService {
  DATABASE
  REDIS
  QDRANT
  STORAGE
  GEMINI
  GROK
  QUEUE
  WEBHOOKS
}

enum SystemStatus {
  ONLINE
  DEGRADED
  OFFLINE
}

// ------------------------------------------------------------
// Identity & Workspace
// ------------------------------------------------------------

model Workspace {
  id           String  @id @default(uuid())
  name         String
  slug         String  @unique
  logo         String?
  country      String
  businessType String
  suspended    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  teamMembers          TeamMember[]
  subscription         Subscription?
  aiProviders          AIProvider[]
  aiEmployees          AIEmployee[]
  knowledgeBases       KnowledgeBase[]
  conversations        Conversation[]
  conversationSessions ConversationSession[]
  customers            Customer[]
  whatsappAccount      WhatsAppAccount?
  facebookPage         FacebookPage?
  instagramAccount     InstagramAccount?
  promptTemplates      PromptTemplate[]
  analytics            Analytics[]
  usage                Usage[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  webhookLogs          WebhookLog[]
  fileProcessingQueue  FileProcessingQueue[]
  emailLogs            EmailLog[]
  paymentLogs          PaymentLog[]

  resources             Resource[]
  services              Service[]
  bookings              Booking[]
  defaultWorkingHours   Json?
  features              WorkspaceFeature[]
  leads                 Lead[]
  workflows             Workflow[]
  apiKeys               ApiKey[]
  webhookSubscriptions  WebhookSubscription[]
  couponRedemptions     CouponRedemption[]
  creditTransactions    CreditTransaction[]
  npsResponses          NpsResponse[]
  referral              Referral?
  promptExperiments     PromptExperiment[]
  customDomain          CustomDomain?
  customerNotes         CustomerNote[]
  primaryColor          String?
  secondaryColor        String?
  favicon               String?
  customCss             String?               @db.Text
  workflowTemplates     WorkflowTemplate[]
  marketplaceApps       MarketplaceApp[]
  marketplaceInstalls   MarketplaceInstall[]

  @@index([slug])
}

/// role is a denormalized mirror of the user's TeamMember.role in their
/// primary workspace, kept for cheap access-control checks without a join.
/// TeamMember stays the source of truth for multi-workspace membership.
model User {
  id       String  @id @default(uuid())
  clerkId  String  @unique
  name     String
  email    String  @unique
  avatar   String?
  role     WorkspaceRole @default(OWNER)
  /// Platform-level flag, unrelated to workspace roles — gates /admin only.
  isSuperAdmin Boolean @default(false)
  language String  @default("ar")
  timezone String  @default("Africa/Cairo")

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  teamMemberships  TeamMember[]
  uploadedFiles    KnowledgeFile[]
  auditLogs        AuditLog[]

  promptVersionsCreated   PromptVersion[]
  authoredNotes           CustomerNote[]
  assignedCustomers       Customer[]
  assignedLeads           Lead[]
  reviewedAppVersions     MarketplaceAppVersion[]
  platformSettingsUpdated PlatformSetting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([email])
}

model TeamMember {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)
  permissions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

// ------------------------------------------------------------
// Subscription & Billing
// ------------------------------------------------------------

model Subscription {
  id          String             @id @default(uuid())
  workspaceId String             @unique
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan   @default(FREE)
  status      SubscriptionStatus @default(TRIALING)
  trialEndsAt DateTime?
  renewAt     DateTime?
  messagesLimit Int              @default(10)
  messagesUsed  Int              @default(0)

  paymentLogs PaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model PaymentLog {
  id             String         @id @default(uuid())
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id])
  provider       String         @default("paymob")
  amount         Decimal        @db.Decimal(10, 2)
  currency       String         @default("EGP")
  status         PaymentStatus  @default(PENDING)
  paymentMethod  PaymentMethod?
  transactionId  String?
  invoiceNumber  String?        @unique
  paymobOrderId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([status])
}

// ------------------------------------------------------------
// AI Employee, Providers & Prompting
// ------------------------------------------------------------

model AIEmployee {
  id                  String         @id @default(uuid())
  workspaceId         String
  workspace           Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role                EmployeeRole   @default(GENERAL)
  isDefault           Boolean        @default(true)
  canManageBookings   Boolean        @default(true)
  name                String
  avatar              String?
  personality         AiPersonality  @default(PROFESSIONAL)
  tone                String         @default("ودود ومحترف")
  language            AiLanguageMode @default(AUTO)
  replyLength         ReplyLength    @default(DETAILED)
  emojiUsage          Boolean        @default(false)
  welcomeMessage      String
  businessDescription String
  systemInstructions  String

  promptVersions    PromptVersion[]
  promptExperiments PromptExperiment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, isDefault])
}

model AIProvider {
  id              String          @id @default(uuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider        AiProviderName
  apiKeyEncrypted String
  defaultModel    String
  enabled         Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

model PromptTemplate {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  systemPrompt String
  temperature  Float     @default(0.7)
  enabled      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

// ------------------------------------------------------------
// Knowledge Base & RAG
// ------------------------------------------------------------

model KnowledgeBase {
  id          String              @id @default(uuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      KnowledgeBaseStatus @default(EMPTY)

  files KnowledgeFile[]
  faqs  KnowledgeFAQ[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model KnowledgeFAQ {
  id              String        @id @default(uuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  question        String
  answer          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([knowledgeBaseId])
}

model KnowledgeFile {
  id                String            @id @default(uuid())
  knowledgeBaseId   String
  knowledgeBase     KnowledgeBase     @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  fileName          String
  fileType          KnowledgeFileType
  fileSize          Int
  storagePath       String
  processingStatus  ProcessingStatus  @default(PENDING)
  uploadedBy        String
  uploader          User              @relation(fields: [uploadedBy], references: [id])

  chunks       KnowledgeChunk[]
  queueEntries FileProcessingQueue[]

  createdAt DateTime @default(now())

  @@index([knowledgeBaseId])
  @@index([processingStatus])
}

model KnowledgeChunk {
  id         String        @id @default(uuid())
  fileId     String
  file       KnowledgeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  chunkIndex Int
  content    String
  tokenCount Int

  embedding Embedding?

  createdAt DateTime @default(now())

  @@index([fileId])
}

/// PostgreSQL never stores the vector itself (see correction: "Never store
/// embeddings inside PostgreSQL. Use Qdrant."). qdrantPointId is the only
/// link between a chunk and its vector.
model Embedding {
  id             String         @id @default(uuid())
  chunkId        String         @unique
  chunk          KnowledgeChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  provider       AiProviderName
  qdrantPointId  String         @unique
  dimensions     Int

  createdAt DateTime @default(now())
}

// ------------------------------------------------------------
// Conversations & Customers
// ------------------------------------------------------------

model Customer {
  id            String   @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String?
  phone         String?
  email         String?
  facebookId    String?
  instagramId   String?
  avatar        String?
  notes         String?

  conversations Conversation[]

  gender         String?
  birthDate      DateTime?
  tags           String[]       @default([])
  status         CustomerStatus @default(ACTIVE)
  source         String?
  assignedUserId String?
  assignedUser   User?          @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  language       String         @default("ar")
  country        String?
  city           String?
  timezone       String?
  crmNotes       CustomerNote[]
  bookings       Booking[]
  convertedFromLead Lead?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([phone])
  @@index([facebookId])
  @@index([instagramId])
}

model Conversation {
  id            String              @id @default(uuid())
  workspaceId   String
  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel       ChannelType
  customerId    String
  customer      Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status        ConversationStatus  @default(ACTIVE)
  lastMessageAt DateTime?
  deletedAt     DateTime?

  messages Message[]
  session  ConversationSession?
  promptExperimentAssignment PromptExperimentAssignment?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([customerId])
  @@index([status])
  @@index([channel])
}

model Message {
  id               String           @id @default(uuid())
  conversationId   String
  conversation     Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender           MessageSender
  messageType      MessageType      @default(TEXT)
  content          String
  attachments      Json?
  aiGenerated      Boolean          @default(false)
  confidenceScore  ConfidenceLevel?
  responseTimeMs   Int?

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

/// Rolling memory for a conversation — summary + extracted facts the AI
/// engine feeds back into the prompt builder so context survives across
/// messages without re-sending full history every time.
model ConversationSession {
  id             String       @id @default(uuid())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  summary        String?
  context        Json?
  deletedAt      DateTime?

  createdAt    DateTime @default(now())
  lastUpdated  DateTime @updatedAt

  @@index([workspaceId])
}

// ------------------------------------------------------------
// Channels
// ------------------------------------------------------------

model WhatsAppAccount {
  id                String                   @id @default(uuid())
  workspaceId       String                   @unique
  workspace         Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phoneNumber       String
  phoneNumberId     String                   @unique
  businessAccountId String                   @unique
  accessToken       String
  status            ChannelConnectionStatus  @default(DISCONNECTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FacebookPage {
  id          String                  @id @default(uuid())
  workspaceId String                  @unique
  workspace   Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pageId      String                  @unique
  pageName    String
  accessToken String
  status      ChannelConnectionStatus @default(DISCONNECTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InstagramAccount {
  id           String                  @id @default(uuid())
  workspaceId  String                  @unique
  workspace    Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  instagramId  String                  @unique
  username     String
  accessToken  String
  status       ChannelConnectionStatus @default(DISCONNECTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------------
// Analytics & Usage
// ------------------------------------------------------------

model Analytics {
  id            String    @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date          DateTime
  messages      Int       @default(0)
  aiReplies     Int       @default(0)
  responseTime  Float?
  knowledgeHits Int       @default(0)

  createdAt DateTime @default(now())

  @@unique([workspaceId, date])
  @@index([workspaceId])
}

model Usage {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date         DateTime
  messagesUsed Int       @default(0)
  aiTokens     Int       @default(0)
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
  storageUsed  Int       @default(0)

  createdAt DateTime @default(now())

  @@unique([workspaceId, date])
  @@index([workspaceId])
}

// ------------------------------------------------------------
// Notifications, Audit & Observability
// ------------------------------------------------------------

model Notification {
  id          String           @id @default(uuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  body        String
  type        NotificationType
  read        Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([read])
}

model AuditLog {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  ip          String?
  device      String?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([createdAt])
}

model WebhookLog {
  id          String          @id @default(uuid())
  workspaceId String?
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  provider    WebhookProvider
  payload     Json
  status      WebhookStatus   @default(RECEIVED)
  response    String?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([provider])
  @@index([status])
}

model FileProcessingQueue {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fileId      String
  file        KnowledgeFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  status      QueueStatus   @default(PENDING)
  step        QueueStep
  startedAt   DateTime?
  finishedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([status])
  @@index([fileId])
}

model EmailLog {
  id             String      @id @default(uuid())
  workspaceId    String?
  workspace      Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  recipientEmail String
  type           EmailType
  status         EmailStatus @default(PENDING)
  resendId       String?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([type])
}

/// Not workspace-scoped — this is platform-wide infrastructure health,
/// consumed by the Admin Panel (Phase 10) and the dashboard status widget.
model SystemHealth {
  id             String        @id @default(uuid())
  service        SystemService
  status         SystemStatus
  responseTimeMs Int?
  message        String?

  createdAt     DateTime @default(now())
  lastCheckedAt DateTime @default(now())

  @@index([service, lastCheckedAt])
}

// ============================================================
// APPENDED MODELS — Orvix OS Phase 2 (all 8 parts + updates)
// ============================================================

// PROPOSAL — modifies AIEmployee in schema.prisma (not yet applied)
//
// Backward-compat plan, since AIEmployee.workspaceId is currently
// @unique (real one-per-workspace constraint right now):
//   1. Add the new fields below with defaults that reproduce today's
//      behavior exactly (role=GENERAL, isDefault=true,
//      canManageBookings=true).
//   2. Drop @unique from workspaceId, keep it as a plain @@index.
//   3. Existing rows need no data migration — every workspace's one
//      existing employee becomes its "default" employee for free,
//      because isDefault defaults to true and there's only one row
//      per workspace anyway at migration time.
//   4. The OLD singular route (/api/v1/ai/employee) is kept working
//      unchanged for any existing frontend — see the two updated route
//      files below. Multiple employees are additive, not a breaking
//      change to what already ships.

enum EmployeeRole {
  GENERAL // today's default — one employee doing everything
  SUPPORT
  SALES
  RECEPTIONIST
  BOOKING
  MARKETING
  FINANCE
  CRM
  ANALYTICS
  KNOWLEDGE_MANAGER
}

// Diff against the existing model:
//
// model AIEmployee {
//   id                  String         @id @default(uuid())
//   workspaceId         String         // <- @unique REMOVED
//   workspace           Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
//   role                EmployeeRole   @default(GENERAL)   // NEW
//   isDefault           Boolean        @default(true)      // NEW — handles channel auto-replies when no per-employee routing exists yet
//   canManageBookings   Boolean        @default(true)      // NEW — employee-level permission, separate from the workspace-level Feature Registry gate
//   name                String
//   avatar              String?
//   personality         AiPersonality  @default(PROFESSIONAL)
//   tone                String         @default("ودود ومحترف")
//   language            AiLanguageMode @default(AUTO)
//   replyLength         ReplyLength    @default(DETAILED)
//   emojiUsage          Boolean        @default(false)
//   welcomeMessage      String
//   businessDescription String
//   systemInstructions  String
//
//   createdAt DateTime @default(now())
//   updatedAt DateTime @updatedAt
//
//   @@index([workspaceId])                    // NEW — replaces the old @unique
//   @@index([workspaceId, isDefault])         // NEW — the lookup generateAiReply does on every message
// }
//
// ============================================================
// ⚠️ REQUIRED companion change — checked against the real repo,
// not theoretical. Workspace's back-relation is currently:
//
//   aiEmployee  AIEmployee?
//
// One-to-one, since AIEmployee.workspaceId used to be @unique. It
// MUST become:
//
//   aiEmployees  AIEmployee[]
//
// This is a breaking rename (aiEmployee -> aiEmployees, singular ->
// array), and grepping the real codebase found exactly THREE places
// that read the old singular shape. All three need this same-session
// fix, or the build breaks:
//
//   1. lib/repositories/workspace.repository.ts — findWithEssentials()
//      currently does `include: { ..., aiEmployee: true, ... }`.
//      Change to:
//        aiEmployees: { where: { isDefault: true }, take: 1 }
//      (fetches just the default employee, as an array of 0-1 —
//      cheaper than fetching every employee when only one is needed here)
//
//   2. features/dashboard/services/dashboard.service.ts — reads
//      `workspace?.aiEmployee` directly. Change to:
//        const defaultEmployee = workspace?.aiEmployees?.[0];
//        ...
//        aiEmployee: defaultEmployee
//          ? { name: defaultEmployee.name, personality: defaultEmployee.personality }
//          : null,
//      Note the RETURNED object's own key stays "aiEmployee" (singular)
//      — this function is the adapter layer, so nothing downstream needs
//      to change.
//
//   3. features/dashboard/components/system-health-card.tsx — reads
//      `data?.aiEmployee?.name`. NO CHANGE NEEDED — it consumes
//      dashboard.service.ts's returned shape (fix #2 above), not the
//      Prisma relation directly, and that returned shape is unchanged.
// ============================================================

// ============================================================
// PROPOSAL — universal booking core (not yet applied)
// Generalizes Phase 2 Part 2 + the "Appointment Setup" update so
// booking works for ANY business type, not just clinics.
//
// Key decision: there is no "Doctor" model. A Resource is
// whatever gets booked — a doctor, a table, a room, a stylist,
// a consultant. Workspace.businessType (already in your schema)
// only drives labels / AI prompt wording — it never shapes the
// data model itself.
//
// Conventions matched to your existing schema.prisma:
// uuid() ids, workspaceId + onDelete: Cascade, createdAt/updatedAt,
// @@index on foreign keys and hot lookup paths.
// ============================================================

enum ResourceKind {
  PERSON  // doctor, stylist, consultant, therapist...
  SPACE   // table, room, court...
  ASSET   // equipment, vehicle...
  GENERIC // no meaningful resource split — AI falls back to workspace hours
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Service {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  durationMin Int
