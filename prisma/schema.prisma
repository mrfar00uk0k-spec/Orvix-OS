// PROPOSAL — append to schema.prisma (not yet applied)
//
// This is the honest, groundable slice of Part 6's "Marketplace" spec:
// reusable Workflow Templates (explicitly named in the doc: Customer
// Support, Payment Reminder, Missed Appointment...). What's NOT here on
// purpose — app review process, revenue splitting, paid third-party
// apps — needs real business decisions (review policy, take-rate %,
// payment provider for marketplace transactions) that aren't technical
// gaps to fill in, they're policy choices for the business to make.
//
// Visibility default: workspaceId nullable + isOfficial flag.
//   workspaceId = null, isOfficial = true  -> built-in starter templates, visible to everyone
//   workspaceId = X,    isOfficial = false -> that workspace's own saved templates, private to them
// No public "share my template with every other business" path exists
// yet — that's a real privacy decision (a saved template can embed a
// business's actual notification wording, AI prompts, etc.) left
// unmade rather than defaulted to "public" without asking.

model WorkflowTemplate {
  id            String     @id @default(uuid())
  workspaceId   String?    // null = official/built-in
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  category      String     // "customer_support", "payment_reminder", "missed_appointment"... free text, same reasoning as WorkspaceFeature.key
  isOfficial    Boolean    @default(false)
  graphSnapshot Json       // { nodes: [...], edges: [...] } — same shape as a real Workflow, minus resolved workspace-specific IDs

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([category])
}

