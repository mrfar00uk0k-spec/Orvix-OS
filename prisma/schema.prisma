// PROPOSAL — append to schema.prisma (not yet applied)
//
// Ledger, not a counter: CreditTransaction rows are the source of
// truth, balance = sum(amount). A mutable `balance Int` field on
// Workspace would need to stay perfectly in sync with every grant/spend
// forever — one missed update anywhere and it silently drifts. Summing
// the ledger can never drift, at the cost of one aggregate query per
// balance check (cheap, and cacheable later if it ever needs to be).

enum CreditReason {
  REFERRAL_BONUS
  ADMIN_GRANT
  LOYALTY_MILESTONE
  AI_MESSAGE_SPEND
  EXTRA_STORAGE_SPEND
}

model CreditTransaction {
  id          String       @id @default(uuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  amount      Int          // positive = grant, negative = spend
  reason      CreditReason
  note        String?

  createdAt DateTime @default(now())

  @@index([workspaceId])
